POSTGRES_DB=fastcheck
POSTGRES_USER=fastcheck
POSTGRES_PASSWORD=change-this-postgres-password
NGINX_PORT=8081

APP_JWT_ISSUER=fastcheck-spring
APP_JWT_ACCESS_TOKEN_MINUTES=30
APP_JWT_REFRESH_TOKEN_DAYS=14
APP_JWT_SECRET=change-this-user-jwt-secret-to-a-long-random-value

FASTAPI_SERVICE_JWT_AUDIENCE=fastcheck-ai
FASTAPI_SERVICE_JWT_SECRET=change-this-service-jwt-secret-to-a-long-random-value
FASTAPI_SERVICE_JWT_TTL_MINUTES=10

APP_FILES_PUBLIC_BASE_URL=https://api.efeatas.dev/api/files
APP_CORS_ALLOWED_ORIGINS=https://efeatas.dev,https://www.efeatas.dev
SPRING_MULTIPART_MAX_FILE_SIZE=20MB
SPRING_MULTIPART_MAX_REQUEST_SIZE=50MB
FASTAPI_CONNECT_TIMEOUT_SECONDS=10
FASTAPI_READ_TIMEOUT_SECONDS=30

AI_APP_ENV=production
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-with-real-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
LLM_REQUEST_TIMEOUT_SECONDS=25
SERVICE_JWT_REQUIRED=true
SERVICE_JWT_ALGORITHMS=HS256
IMAGE_FETCH_TIMEOUT_SECONDS=20
IMAGE_MAX_BYTES=12000000
