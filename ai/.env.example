OPENROUTER_API_KEY=put_openrouter_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

SERVICE_JWT_REQUIRED=true
SERVICE_JWT_ALGORITHMS=HS256
SERVICE_JWT_SECRET=replace_with_shared_secret
# Optional: if backend exposes FASTAPI_SERVICE_JWT_SECRET, AI can read it too
FASTAPI_SERVICE_JWT_SECRET=
SERVICE_JWT_ISSUER=fastcheck-spring
SERVICE_JWT_AUDIENCE=fastcheck-ai

IMAGE_FETCH_TIMEOUT_SECONDS=20
IMAGE_MAX_BYTES=12000000
